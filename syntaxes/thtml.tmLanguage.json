
{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "thtml",
  "scopeName": "text.html.thtml",
  "fileTypes": ["thtml"],
  "patterns": [
    { "include": "#frontmatter" },
    { "include": "#comment" },
    { "include": "#expression" },
    { "include": "#block" },
    { "include": "#html" }
  ],
  "repository": {

    "frontmatter": {
      "name": "meta.frontmatter.thtml",
      "begin": "^(---)\\s*$",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.frontmatter.thtml" }
      },
      "end": "^(---)\\s*$",
      "endCaptures": {
        "1": { "name": "punctuation.definition.frontmatter.thtml" }
      },
      "contentName": "source.ts",
      "patterns": [
        { "include": "source.ts" }
      ]
    },

    "comment": {
      "name": "comment.block.thtml",
      "begin": "(\\{#)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.comment.begin.thtml" }
      },
      "end": "(#\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.comment.end.thtml" }
      }
    },

    "expression": {
      "name": "meta.template.expression.thtml",
      "begin": "(\\{\\{)-?",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.thtml" }
      },
      "end": "-?(\\}\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.thtml" }
      },
      "patterns": [
        { "include": "#raw-operator" },
        { "include": "source.ts" }
      ]
    },

    "raw-operator": {
      "match": "(?<=\\{\\{-?\\s*)(!)",
      "captures": {
        "1": { "name": "keyword.operator.raw.thtml" }
      }
    },

    "block": {
      "name": "meta.template.block.thtml",
      "begin": "(\\{%)-?",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.thtml" }
      },
      "end": "-?(%\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.thtml" }
      },
      "patterns": [
        { "include": "#block-keywords" },
        { "include": "source.ts" }
      ]
    },

    "block-keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.thtml",
          "match": "\\b(if|else|elif|endif)\\b"
        },
        {
          "name": "keyword.control.loop.thtml",
          "match": "\\b(for|endfor|of|in)\\b"
        },
        {
          "name": "keyword.control.include.thtml",
          "match": "\\b(include)\\b"
        },
        {
          "name": "keyword.other.assignment.thtml",
          "match": "\\b(set)\\b"
        }
      ]
    },

    "html": {
      "patterns": [
        { "include": "text.html.basic" }
      ]
    }

  }
}
