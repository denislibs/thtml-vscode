{
  "name": "thtml-vscode",
  "private": true,
  "displayName": "thtml — HTML Template Engine",
  "description": "Syntax highlighting, autocomplete and type checking for .thtml template files",
  "version": "0.1.2",
  "publisher": "thtml",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/denislibs/thtml-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "thtml",
    "template",
    "html",
    "typescript"
  ],
  "icon": "assets/icon.png",
  "activationEvents": [
    "onLanguage:thtml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "thtml",
        "aliases": [
          "thtml",
          "HTML Template"
        ],
        "extensions": [
          ".thtml"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/icon.png",
          "dark": "./assets/icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "thtml",
        "scopeName": "text.html.thtml",
        "path": "./syntaxes/thtml.tmLanguage.json",
        "embeddedLanguages": {
          "source.ts": "typescript",
          "text.html.basic": "html"
        }
      }
    ],
    "commands": [
      {
        "command": "thtml.restart",
        "title": "thtml: Restart Language Server"
      },
      {
        "command": "thtml.showOutput",
        "title": "thtml: Show Output Channel"
      },
      {
        "command": "thtml.previewTemplate",
        "title": "thtml: Preview Template",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "thtml.previewTemplate",
          "when": "resourceLangId == thtml",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "thtml",
      "properties": {
        "thtml.languageServer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable thtml language server (autocomplete, hover docs, diagnostics)."
        },
        "thtml.languageServer.trace": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the thtml language server."
        },
        "thtml.validate.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time validation of .thtml files."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@thtml/language-server": "^0.1.1",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.4.5"
  }
}